# Copy to ".env" next to docker-compose.yml (do not commit .env).
# Required on servers where the image was built without appsettings.json (typical after git clone).

CONNECTION_STRING=Server=YOUR_RDS_HOST;Port=3306;Database=VinhKhanhFoodTour;Uid=YOUR_USER;Pwd=YOUR_PASSWORD;CharSet=utf8mb4;SslMode=Required;
JWT_KEY=REPLACE_WITH_AT_LEAST_32_CHAR_RANDOM_SECRET
