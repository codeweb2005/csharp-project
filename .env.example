# ─────────────────────────────────────────────────────────────────────────────
# Vinh Khanh Food Tour — Docker Compose environment variables
# Copy file này thành ".env" (cùng thư mục với docker-compose.yml).
# KHÔNG commit file .env vào git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (BẮT BUỘC) ────────────────────────────────────────────────────────
CONNECTION_STRING=Server=YOUR_DB_HOST;Port=3306;Database=VinhKhanhFoodTour;Uid=YOUR_USER;Pwd=YOUR_PASSWORD;CharSet=utf8mb4;SslMode=None;
JWT_KEY=REPLACE_WITH_AT_LEAST_32_CHAR_RANDOM_SECRET_KEY_HERE

# ── File Storage ──────────────────────────────────────────────────────────────
# "local" = lưu trong container volume /app/uploads (mặc định)
# "s3"    = cần thêm AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, S3_BUCKET
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_BASE_URL=http://localhost:8080/uploads

# ── Frontend API URL (browser-reachable) ─────────────────────────────────────
# Admin & Vendor frontend dùng biến này để gọi API từ trình duyệt.
# Phải là địa chỉ mà HOST (trình duyệt của bạn) có thể truy cập.
# Trong môi trường local: http://localhost:8080/api/v1
# Trên server: https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1

# SignalR hub URL (admin-frontend LiveMonitor)
VITE_HUB_URL=http://localhost:8080/hubs

# ── Visitor frontend ──────────────────────────────────────────────────────────
# Visitor dùng Vite proxy nội bộ → VITE_DEV_API_PROXY_TARGET trỏ đến container.
# Không cần thay đổi nếu chạy local.
# VITE_DEV_API_PROXY_TARGET=http://backend:8080
# VISITOR_BASE_PATH=/

# ── Port overrides (tuỳ chọn) ─────────────────────────────────────────────────
# API_PORT=8080
# ADMIN_VITE_PORT=5173
# VENDOR_VITE_PORT=5174
# VISITOR_VITE_PORT=5175
