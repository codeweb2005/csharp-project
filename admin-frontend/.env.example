# ============================================================
# Admin Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# DO NOT commit your actual API key to git!
# ============================================================

# Backend API base URL
VITE_API_BASE_URL=http://localhost:5015/api/v1

# Google Maps JavaScript API key.
# Used by the MapPicker component on the POI create/edit form.
# If left empty, MapPicker falls back to manual lat/lng text inputs.
# Get a key: https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Places API (optional)
VITE_GOOGLE_MAPS_API_KEY=
