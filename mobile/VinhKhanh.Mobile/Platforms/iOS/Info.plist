<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>

	<!-- ══ Location permissions ══════════════════════════════════════════ -->

	<!-- iOS 14+ requires this key; without it the WhenInUse permission dialog won't show -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Vinh Khanh Food Tour uses your location to detect when you are near a restaurant and automatically play its audio narration.</string>

	<!--
	  Required for background location (AllowsBackgroundLocationUpdates = true).
	  iOS requires BOTH keys when requesting Always authorization.
	  The app requests Always so GPS continues when the screen is locked while touring.
	-->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Vinh Khanh Food Tour needs background location access to automatically play audio narrations as you walk past restaurants, even when your screen is off.</string>

	<key>NSLocationAlwaysUsageDescription</key>
	<string>To provide automatic audio narrations while you tour Vinh Khanh food street, the app tracks your location continuously in the background.</string>

	<!--
	  UIBackgroundModes → location:
	  Declares that this app uses background location services.
	  Required for CLLocationManager.AllowsBackgroundLocationUpdates = true to work.
	  Without this key, iOS will throw an exception at runtime when setting that property.
	-->
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
	</array>

</dict>
</plist>
