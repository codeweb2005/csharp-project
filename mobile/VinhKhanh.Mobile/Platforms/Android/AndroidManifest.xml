<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <application android:allowBackup="true"
                 android:icon="@mipmap/appicon"
                 android:roundIcon="@mipmap/appicon_round"
                 android:supportsRtl="true"
                 android:usesCleartextTraffic="true"
                 android:label="Vinh Khanh Food Tour">

        <!--
          GpsTrackerService — the foreground service that keeps GPS alive in the background.
          foregroundServiceType="location" is required on Android 10+ for location-type services.
          exported="false" prevents other apps from binding to this service.
        -->
        <service
            android:name="vinhkhanh.mobile.platforms.android.GpsTrackerService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>

    <!-- Network access for API calls and audio streaming -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Location permissions:
        ACCESS_FINE_LOCATION    → GPS for precise geofence detection (required)
        ACCESS_COARSE_LOCATION  → Network-based fallback location (required on Android 12+
                                  when requesting fine location at runtime)
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!--
      Background location (Android 10+ / API 29+).
      Required for GPS tracking when the screen is off.
      Must be requested separately at runtime AFTER fine location is granted.
      Google Play requires a Play Store disclosure when this permission is declared.
    -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!--
      Foreground service permissions.
      FOREGROUND_SERVICE          → Required on Android 9+ (API 28+).
      FOREGROUND_SERVICE_LOCATION → Required on Android 14+ (API 34+) for location-type foreground services.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!--
      POST_NOTIFICATIONS — Required on Android 13+ (API 33+) to show any notification,
      including the persistent GPS foreground service notification.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Declare that GPS hardware is required.
      The Play Store will filter out GPS-less devices.
    -->
    <uses-feature android:name="android.hardware.location.gps" android:required="true" />
</manifest>
