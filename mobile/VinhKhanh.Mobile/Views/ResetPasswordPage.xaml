<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanh.Mobile.Views.ResetPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Reset password"
    BackgroundColor="#0F172A">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringNotEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="24">
        <VerticalStackLayout Spacing="14">

            <Label Text="New password"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#F1F5F9" />

            <Label Text="Enter the code from your email (or dev response) and choose a new password."
                   TextColor="#64748B"
                   FontSize="13" />

            <Entry Placeholder="Email"
                   Text="{Binding Email}"
                   Keyboard="Email"
                   TextColor="#F1F5F9"
                   PlaceholderColor="#64748B" />

            <Entry Placeholder="Reset code"
                   Text="{Binding Token}"
                   TextColor="#F1F5F9"
                   PlaceholderColor="#64748B" />

            <Entry Placeholder="New password (min 8 characters)"
                   Text="{Binding NewPassword}"
                   IsPassword="True"
                   TextColor="#F1F5F9"
                   PlaceholderColor="#64748B" />

            <Entry Placeholder="Confirm new password"
                   Text="{Binding ConfirmPassword}"
                   IsPassword="True"
                   TextColor="#F1F5F9"
                   PlaceholderColor="#64748B" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="#F87171"
                   FontSize="13"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Label Text="{Binding InfoMessage}"
                   TextColor="#86EFAC"
                   FontSize="13"
                   IsVisible="{Binding InfoMessage, Converter={StaticResource StringNotEmptyConverter}}" />

            <Button Text="Update password"
                    Command="{Binding SubmitCommand}"
                    BackgroundColor="#6366F1"
                    TextColor="White"
                    CornerRadius="12"
                    HeightRequest="48" />

            <Button Text="Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Transparent"
                    TextColor="#64748B" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#6366F1" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
