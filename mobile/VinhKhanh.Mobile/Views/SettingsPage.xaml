<?xml version="1.0" encoding="utf-8" ?>
<!--
    SettingsPage.xaml — User-configurable GPS, geofence and audio settings.

    Tasks covered:
      T-06: Geofence radius, GPS poll, debounce, cooldown sliders + auto-play toggle
      T-07: TTS voice picker per device locale
      T-09: Manual sync + last-sync label
      T-11: (notification permission requested from SettingsViewModel on load)

    Layout:
      ┌──────────────────────────────────────────┐
      │  ⚙️  Settings                            │
      │  ─────────────────────────────────────── │
      │  GPS & Geofence                          │
      │    Radius: [50 ──────○───── 500] m       │
      │    GPS interval: [3 ───○─── 15] s        │
      │    Debounce: [1 ──○── 5] readings        │
      │    Cooldown: [1 ────────○ 15] min        │
      │  Narration                               │
      │    Auto-play:  [toggle]                  │
      │    TTS Voice:  [picker]                  │
      │  Sync                                    │
      │    Last sync: 5m ago                     │
      │    [Sync Now]                            │
      │  [Reset to defaults]                     │
      └──────────────────────────────────────────┘
-->
<ContentPage
    x:Class="VinhKhanh.Mobile.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:VinhKhanh.Mobile.ViewModels"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Settings"
    BackgroundColor="#0F172A">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="Label" x:Key="SectionHeader">
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="#6366F1" />
                <Setter Property="Margin" Value="0,16,0,4" />
            </Style>
            <Style TargetType="Label" x:Key="SettingLabel">
                <Setter Property="TextColor" Value="#CBD5E1" />
                <Setter Property="FontSize" Value="14" />
            </Style>
            <Style TargetType="Label" x:Key="ValueLabel">
                <Setter Property="TextColor" Value="#94A3B8" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="HorizontalOptions" Value="End" />
            </Style>
            <toolkit:InvertedBoolConverter x:Key="InvertBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="4">

            <!-- Page title -->
            <Label Text="⚙️  Settings"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#F1F5F9"
                   Margin="0,4,0,8" />

            <!-- ── GPS & Geofence ─────────────────────────────────────────── -->
            <Border BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1" Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="📡  GPS &amp; Geofence" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>

                    <!-- Geofence radius -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Detection radius" Style="{StaticResource SettingLabel}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding GeofenceRadiusMeters, StringFormat='{0} m'}"
                               Style="{StaticResource ValueLabel}" VerticalOptions="Center"/>
                    </Grid>
                    <Slider
                        x:Name="RadiusSlider"
                        Minimum="50" Maximum="500" Value="{Binding GeofenceRadiusMeters}"
                        MinimumTrackColor="#6366F1" ThumbColor="#818CF8"
                        MaximumTrackColor="#334155" />

                    <!-- GPS poll interval -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="GPS poll interval" Style="{StaticResource SettingLabel}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding GpsPollIntervalSeconds, StringFormat='{0} s'}"
                               Style="{StaticResource ValueLabel}" VerticalOptions="Center"/>
                    </Grid>
                    <Slider
                        Minimum="3" Maximum="15" Value="{Binding GpsPollIntervalSeconds}"
                        MinimumTrackColor="#6366F1" ThumbColor="#818CF8"
                        MaximumTrackColor="#334155" />

                    <!-- Debounce readings -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Debounce readings" Style="{StaticResource SettingLabel}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding DebounceReadings, StringFormat='{0}x'}"
                               Style="{StaticResource ValueLabel}" VerticalOptions="Center"/>
                    </Grid>
                    <Slider
                        Minimum="1" Maximum="5" Value="{Binding DebounceReadings}"
                        MinimumTrackColor="#6366F1" ThumbColor="#818CF8"
                        MaximumTrackColor="#334155" />

                    <!-- Cooldown per POI -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Cooldown per POI" Style="{StaticResource SettingLabel}" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding CooldownMinutes, StringFormat='{0} min'}"
                               Style="{StaticResource ValueLabel}" VerticalOptions="Center"/>
                    </Grid>
                    <Slider
                        Minimum="1" Maximum="15" Value="{Binding CooldownMinutes}"
                        MinimumTrackColor="#6366F1" ThumbColor="#818CF8"
                        MaximumTrackColor="#334155" />

                </VerticalStackLayout>
            </Border>

            <!-- ── Narration ─────────────────────────────────────────────── -->
            <Border BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1" Padding="16" Margin="0,8,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="🎙️  Narration" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>

                    <!-- Auto-play toggle -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Auto-play when entering a POI"
                               Style="{StaticResource SettingLabel}"
                               VerticalOptions="Center"/>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding AutoPlayNarration}"
                                OnColor="#6366F1"
                                VerticalOptions="Center"/>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#334155" Margin="0,4"/>

                    <!-- TTS Voice picker (T-07) -->
                    <Label Text="TTS Voice" Style="{StaticResource SettingLabel}"/>
                    <Picker
                        ItemsSource="{Binding AvailableVoices}"
                        SelectedItem="{Binding SelectedVoice}"
                        BackgroundColor="#0F172A"
                        TextColor="#CBD5E1"
                        TitleColor="#64748B"
                        Title="Select a voice…" />

                    <Button Text="Reload available voices"
                            Command="{Binding LoadVoicesCommand}"
                            BackgroundColor="Transparent"
                            BorderColor="#334155"
                            BorderWidth="1"
                            TextColor="#94A3B8"
                            FontSize="13"
                            HeightRequest="40"
                            CornerRadius="8" />

                </VerticalStackLayout>
            </Border>

            <!-- ── Sync ──────────────────────────────────────────────────── -->
            <Border BackgroundColor="#1E293B" Stroke="#334155" StrokeThickness="1" Padding="16" Margin="0,8,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="🔄  Data Sync" Style="{StaticResource SectionHeader}" Margin="0,0,0,4"/>

                    <Label Text="{Binding LastSyncText}"
                           TextColor="#64748B"
                           FontSize="13" />

                    <Button Text="Sync POI data now"
                            Command="{Binding SyncNowCommand}"
                            BackgroundColor="#6366F1"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="44"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBool}}" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       Color="#6366F1" />

                    <Label Text="{Binding StatusMessage}"
                           IsVisible="{Binding StatusMessage, Converter={toolkit:IsStringNotNullOrEmptyConverter}}"
                           TextColor="#94A3B8"
                           FontSize="13"
                           HorizontalOptions="Center" />

                </VerticalStackLayout>
            </Border>

            <!-- ── Reset ─────────────────────────────────────────────────── -->
            <Button Text="Reset all to defaults"
                    Command="{Binding ResetToDefaultsCommand}"
                    BackgroundColor="Transparent"
                    BorderColor="#475569"
                    BorderWidth="1"
                    TextColor="#F87171"
                    HeightRequest="48"
                    CornerRadius="12"
                    Margin="0,16,0,32" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
