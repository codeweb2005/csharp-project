<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="VinhKhanh.Mobile.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
    Title="Map"
    BackgroundColor="#0F172A">

    <Grid RowDefinitions="Auto,*">

        <!-- Header: status + refresh -->
        <Grid Grid.Row="0" Padding="12,8" ColumnDefinitions="*,Auto"
              BackgroundColor="#1E293B">
            <Label Grid.Column="0"
                   Text="{Binding StatusText}"
                   TextColor="#94A3B8"
                   FontSize="13"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="Refresh"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="#312E81"
                    TextColor="#E0E7FF"
                    Padding="12,6"
                    CornerRadius="8"
                    FontSize="13" />
        </Grid>

        <!-- Mapsui native map — OSM tiles, POI pins, geofence circles, user dot -->
        <Grid Grid.Row="1">
            <!-- Explicit fill + min size helps first layout pass before Skia allocates (avoids crashes on some devices). -->
            <mapsui:MapControl
                x:Name="TourMapControl"
                HorizontalOptions="Fill"
                VerticalOptions="Fill"
                MinimumHeightRequest="200"
                MinimumWidthRequest="200" />

            <Label Text="{Binding ErrorMessage}"
                   TextColor="#F87171"
                   BackgroundColor="#1E293B"
                   Padding="12"
                   Margin="12"
                   HorizontalOptions="Fill"
                   VerticalOptions="Start"
                   IsVisible="{Binding ErrorMessage,
                       Converter={toolkit:IsStringNotNullOrEmptyConverter}}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#6366F1"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               ZIndex="2" />
        </Grid>

    </Grid>
</ContentPage>
