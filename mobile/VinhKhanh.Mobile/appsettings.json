{
  /*
   * appsettings.json — Mobile app configuration
   *
   * This file is embedded as a resource in the binary (EmbeddedResource in .csproj).
   * ApiClient reads it at runtime via GetManifestResourceStream().
   *
   * CHANGE ApiBaseUrl when deploying to production:
   *   Development : "http://10.0.2.2:5015/api/v1"   ← Android emulator localhost
   *   LAN device  : "http://192.168.x.x:5015/api/v1"
   *   Production  : "https://api.vinhkhanh.com/api/v1"
   */
  "ApiBaseUrl": "http://10.0.2.2:5015/api/v1",

  /*
   * DefaultRadius — how far (metres) to search for nearby POIs on app launch.
   * The backend caps this at 5000m in POIsController.GetNearby.
   */
  "DefaultRadiusMeters": 500,

  /*
   * DebounceReadings — number of consecutive GPS readings that must place the user
   * inside a POI's geofence before GeofenceEntered fires. At 5s poll interval,
   * 3 readings ≈ 15 seconds of dwell time to prevent accidental triggers.
   */
  "DebounceReadings": 3,

  /*
   * LocationPollIntervalSeconds — how often the location service polls GPS.
   * Lower = more battery drain; higher = less responsive geofence detection.
   */
  "LocationPollIntervalSeconds": 5
}
