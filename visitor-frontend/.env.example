# Visitor site — copy to .env for local development

# Required: API base URL as resolved in the browser (must include /api/v1).
# Use your published API host (e.g. Docker: http://localhost:8080/api/v1).
VITE_API_BASE_URL=http://localhost:5015/api/v1

# Optional: if the built app is served under a subpath (e.g. https://example.com/visit/), set:
# VITE_BASE_PATH=/visit/

# Optional: dev-only proxy. Set VITE_API_BASE_URL to same origin as Vite, e.g.:
#   VITE_API_BASE_URL=http://localhost:5175/api/v1
# Then /api/v1 requests are forwarded to the real API (default below matches dotnet run on host).
# VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:5015
